               </font></Button>
            <Button fx:id="btnAddition" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnAdditionAction" style="-fx-background-color: black;" text="+" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="1">
