            <Button fx:id="btnResultat" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnResultatAction" prefHeight="25.0" prefWidth="26.0" style="-fx-background-color: orange;" text="=" GridPane.columnIndex="4" GridPane.rowIndex="3" />
