            <Button fx:id="btnSoustraction" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnSoustractionAction" style="-fx-background-color: black;" text=" -" textFill="WHITE" GridPane.columnIndex="3" GridPane.rowIndex="2">
