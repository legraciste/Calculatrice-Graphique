      <TextField fx:id="txtFieldResultat" maxWidth="506.0" minHeight="32.0" minWidth="50.0" prefHeight="43.0" prefWidth="506.0" />
      <Button fx:id="btnEffacer" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnEffacerAction" prefHeight="25.0" prefWidth="69.0" style="-fx-background-color: red;" text="Effacer" textFill="WHITE">
         <VBox.margin>
            <Insets left="-260.0" />
         </VBox.margin>
      </Button>
      <GridPane minWidth="57.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Button fx:id="btnSept" mnemonicParsing="false" onAction="#onBtnSeptAction" prefHeight="0.0" prefWidth="56.0" text="7" />
            <Button fx:id="btnQuatre" mnemonicParsing="false" onAction="#onBtnQuatreAction" prefHeight="25.0" prefWidth="56.0" text="4" GridPane.rowIndex="1" />
            <Button fx:id="btnUn" mnemonicParsing="false" onAction="#onBtnUnAction" prefHeight="25.0" prefWidth="56.0" text="1" GridPane.rowIndex="2" />
            <Button fx:id="btnHuite" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnHuiteAction" text="8" GridPane.columnIndex="1" />
            <Button fx:id="btnCinq" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnCinqAction" text="5" GridPane.columnIndex="1" GridPane.rowIndex="1" />
