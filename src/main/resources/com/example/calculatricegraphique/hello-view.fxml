<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.calculatricegraphique.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <TextField fx:id="txtFieldResultat" />
      <Button fx:id="btnEffacer" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnEffacerAction" text="Effacer">
         <VBox.margin>
            <Insets left="-445.0" />
         </VBox.margin>
      </Button>
      <GridPane minWidth="57.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Button fx:id="btnSept" mnemonicParsing="false" onAction="#onBtnSeptAction" prefHeight="0.0" prefWidth="56.0" text="7" />
            <Button fx:id="btnQuatre" mnemonicParsing="false" onAction="#onBtnQuatreAction" prefHeight="25.0" prefWidth="56.0" text="4" GridPane.rowIndex="1" />
            <Button fx:id="btnUn" mnemonicParsing="false" onAction="#onBtnUnAction" prefHeight="25.0" prefWidth="56.0" text="1" GridPane.rowIndex="2" />
            <Button fx:id="btnHuite" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnHuiteAction" text="8" GridPane.columnIndex="1" />
            <Button fx:id="btnCinq" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnCinqAction" text="5" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Button fx:id="btnDeux" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnDeuxAction" text="2" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Button fx:id="btnNeuf" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnNeufAction" text="9" GridPane.columnIndex="2" />
            <Button fx:id="btnSix" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnSixAction" text="6" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <Button fx:id="btnTrois" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnTroisAction" text="3" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <Button fx:id="btnParentheseGauche" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnParentheseGauche" text="(" GridPane.columnIndex="3" />
            <Button fx:id="btnAddition" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnAdditionAction" text="+" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            <Button fx:id="btnSoustraction" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnSoustractionAction" text=" -" GridPane.columnIndex="3" GridPane.rowIndex="2" />
            <Button mnemonicParsing="false" prefHeight="25.0" prefWidth="57.0" text="0" GridPane.rowIndex="3" />
            <Button minWidth="57.0" mnemonicParsing="false" text="⋅" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Button fx:id="btnSupprimer" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnSupprimerAction" text="supp" GridPane.columnIndex="2" GridPane.rowIndex="3" />
            <Button fx:id="btnParentheseDroite" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnParentheseDroite" text=")" GridPane.columnIndex="4" />
            <Button fx:id="btnDivision" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnDivisionAction" text="÷" GridPane.columnIndex="4" GridPane.rowIndex="1" />
            <Button fx:id="btnMultiplication" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnMultiplicationAction" text="×" GridPane.columnIndex="4" GridPane.rowIndex="2" />
            <Button fx:id="btnResultat" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnResultatAction" prefHeight="25.0" prefWidth="26.0" text="=" GridPane.columnIndex="4" GridPane.rowIndex="3" />
         </children>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </GridPane>
   </children>
</VBox>
