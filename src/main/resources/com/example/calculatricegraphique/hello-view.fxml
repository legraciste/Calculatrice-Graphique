            <Button fx:id="btnDivision" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnDivisionAction" style="-fx-background-color: black;" text="÷" textFill="WHITE" GridPane.columnIndex="4" GridPane.rowIndex="1" />
            <Button fx:id="btnMultiplication" minWidth="57.0" mnemonicParsing="false" onAction="#onBtnMultiplicationAction" style="-fx-background-color: black;" text="×" textFill="WHITE" GridPane.columnIndex="4" GridPane.rowIndex="2">
